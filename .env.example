# ===========================
# GRANTIQ 환경변수 설정
# ===========================
# 이 파일을 복사해서 .env.local 로 저장 후 값을 채워주세요

# [필수] Anthropic API Key
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# [선택] Slack 연동
# Incoming Webhook: https://api.slack.com/apps → Incoming Webhooks → Add New Webhook
# 공고/사업계획서 공유할 채널 선택 후 URL 복사
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/xxxxxxxx

# Bot Token (채널 지정 메시지 전송용, 연구노트 등)
# Slack App → OAuth & Permissions → Bot Token Scopes: chat:write
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxx

# 메시지 보낼 기본 채널 ID (채널 우클릭 → Copy Channel ID)
SLACK_CHANNEL_ID=C0XXXXXXXXX

# [선택] Google Drive 연동
GOOGLE_SERVICE_ACCOUNT_EMAIL=grantiq@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxxx\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [선택] 기업 설정
COMPANY_NAME=㈜움틀


# [자율 에이전트] 주간 이사회 보고
# Vercel Cron 보안 키 (아무 문자열이나 설정)
CRON_SECRET=my-secret-key-here
# 배포 후 Vercel이 준 URL 입력
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
